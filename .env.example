# ── Vega SOC configuration ────────────────────────────────────────────────────
# Copy to .env and fill in. The .env file is git-ignored — never commit real keys.

# Server's own IPs (comma-separated). Used to identify OUTBOUND flows in rules R3/R5.
# Include LAN IP, any secondary interfaces, and VPN/Tailscale IP.
SOC_SERVER_IPS=10.0.0.10,192.168.1.20

# ── Telegram (operator interface) ─────────────────────────────────────────────
# Bot token from @BotFather; chat ID from @userinfobot.
# Required for alerts to reach you. System runs without them (logs to journal instead).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Threat intel (optional — Intel agent degrades gracefully without these) ────
# AbuseIPDB: free tier 1,000 checks/day — https://www.abuseipdb.com
ABUSEIPDB_API_KEY=
# IPinfo: free tier 50k/month — https://ipinfo.io
IPINFO_TOKEN=

# ── Dashboard ─────────────────────────────────────────────────────────────────
SOC_DASHBOARD_PORT=9200
